{
  "name": "cafe-orders",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "lint": "eslint . && stylelint \"src/**/*.scss\"",
    "format:check": "prettier . --check",
    "mock": "json-server server/db.json --port 3001",
    "mock:server": "json-server server/db.json --port 3001"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ngrx/signals": "^21.1.0",
    "@taiga-ui/core": "^5.3.0",
    "@taiga-ui/kit": "^5.3.0",
    "@taiga-ui/layout": "^5.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "jsdom": "^27.1.0",
    "json-server": "^1.0.0-beta.15",
    "less": "^4.6.4",
    "prettier": "^3.8.3",
    "stylelint": "^17.9.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.0.8"
  }
}
